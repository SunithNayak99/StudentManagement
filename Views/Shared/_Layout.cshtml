<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - School Management</title>
<link href="~/Content/bootstrap.min.css" rel="stylesheet" />
<link href="~/Content/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/Content/instagram-style.css" rel="stylesheet" />
    @RenderSection("styles", required: false)
</head>
@{
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var showSidebar = action != "Login" && action != "Signup";
}
<body>
    @if (showSidebar)
    {
        <nav class="navbar navbar-expand-lg site-nav">
            <div class="container-fluid px-3">
                <button class="sidebar-toggle me-3" id="sidebarToggle" aria-label="Toggle sidebar">
                    <i class="bi bi-list"></i>
                </button>
                @Html.ActionLink("School Management", "Dashboard", "Home", new { area = "" }, new { @class = "navbar-brand" })
                <div class="d-flex align-items-center gap-2 ms-auto">
                    <span class="text-muted">Admin</span>
                </div>
            </div>
        </nav>

        <div class="app-layout">
            <aside class="sidebar" id="sidebar">
                <div class="sidebar-header">
                    <h3><i class="bi bi-mortarboard-fill"></i> School Portal</h3>
                    <p>Management System</p>
                </div>
                <nav class="sidebar-nav">
                    <a href="@Url.Action("Dashboard", "Home")" class="sidebar-link @(action == "Dashboard" ? "active" : "")">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                    
                    <div class="sidebar-section-title">Academic</div>
                    
                    <a href="@Url.Action("StudentRegistration", "Home")" class="sidebar-link @(action == "StudentRegistration" ? "active" : "")">
                        <i class="bi bi-person-plus-fill"></i>
                        <span>Student Registration</span>
                    </a>
                    <a href="@Url.Action("TeacherAdd", "Home")" class="sidebar-link @(action == "TeacherAdd" ? "active" : "")">
                        <i class="bi bi-person-badge-fill"></i>
                        <span>Teacher Add</span>
                    </a>
                    <a href="@Url.Action("ClassCreation", "Home")" class="sidebar-link @(action == "ClassCreation" ? "active" : "")">
                        <i class="bi bi-door-open-fill"></i>
                        <span>Class Creation</span>
                    </a>
                    <a href="@Url.Action("SubjectManagement", "Home")" class="sidebar-link @(action == "SubjectManagement" ? "active" : "")">
                        <i class="bi bi-book-fill"></i>
                        <span>Subject Management</span>
                    </a>
                    
                    <div class="sidebar-section-title">Operations</div>
                    
                    <a href="@Url.Action("Attendance", "Home")" class="sidebar-link @(action == "Attendance" ? "active" : "")">
                        <i class="bi bi-calendar-check-fill"></i>
                        <span>Attendance</span>
                    </a>
                    <a href="@Url.Action("FeesCollection", "Home")" class="sidebar-link @(action == "FeesCollection" ? "active" : "")">
                        <i class="bi bi-currency-dollar"></i>
                        <span>Fees Collection</span>
                    </a>
                    <a href="@Url.Action("ExamManagement", "Home")" class="sidebar-link @(action == "ExamManagement" ? "active" : "")">
                        <i class="bi bi-journal-check"></i>
                        <span>Exam Management</span>
                    </a>
                    
                    <div class="sidebar-divider"></div>
                    
                    <a href="@Url.Action("Login", "Home")" class="sidebar-link sidebar-logout">
                        <i class="bi bi-box-arrow-left"></i>
                        <span>Logout</span>
                    </a>
                </nav>
            </aside>
            <div class="sidebar-overlay" id="sidebarOverlay"></div>

            <main class="page-shell">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </main>
        </div>
    }
    else
    {
        @RenderBody()
    }

   <script src="~/Scripts/jquery.min.js"></script>
<script src="~/Scripts/bootstrap.bundle.min.js"></script>
    @if (showSidebar)
    {
        <script src="~/JavaScript/dashboard.js"></script>
    }
    @RenderSection("scripts", required: false)
</body>
</html>
