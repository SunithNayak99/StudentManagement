<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Student Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="~/Content/student-dashboard.css" rel="stylesheet" />
    @RenderSection("styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg site-nav">
        <div class="container">
            @Html.ActionLink("StudentHub", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">@Html.ActionLink("Home", "Index", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("About", "About", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Contact", "Contact", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    @Html.ActionLink("Login", "Login", "Home", new { area = "" }, new { @class = "btn btn-outline-light" })
                    @Html.ActionLink("Sign Up", "Signup", "Home", new { area = "" }, new { @class = "action-btn" })
                </div>
            </div>
        </div>
    </nav>

    <main class="page-shell">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h5 class="footer-title">StudentHub</h5>
                    <p class="footer-text">A modern dashboard built for managing student success, schedules, and communication in one place.</p>
                </div>
                <div class="col-lg-4">
                    <h6 class="footer-heading">Quick Links</h6>
                    <ul class="list-unstyled footer-links">
                        <li>@Html.ActionLink("Dashboard", "Index", "Home", new { area = "" }, new { @class = "footer-link" })</li>
                        <li>@Html.ActionLink("About", "About", "Home", new { area = "" }, new { @class = "footer-link" })</li>
                        <li>@Html.ActionLink("Contact", "Contact", "Home", new { area = "" }, new { @class = "footer-link" })</li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h6 class="footer-heading">Connect</h6>
                    <div class="d-flex gap-3">
                        <a class="footer-icon" href="#"><i class="bi bi-linkedin"></i></a>
                        <a class="footer-icon" href="#"><i class="bi bi-twitter-x"></i></a>
                        <a class="footer-icon" href="#"><i class="bi bi-instagram"></i></a>
                    </div>
                    <p class="footer-text mt-3 mb-0">&copy; @DateTime.Now.Year StudentHub. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/student-dashboard.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
