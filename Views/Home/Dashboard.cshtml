@{
    ViewBag.Title = "Dashboard";
}

<div class="dashboard-header mb-4">
    <div>
        <h2 class="dashboard-title">School <span>Dashboard</span></h2>
        <p class="text-muted">Welcome to School Management System</p>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="stat-box">
            <div class="stat-icon" style="background: rgba(16, 185, 129, 0.15);">
                <i class="bi bi-people" style="color: #10b981;"></i>
            </div>
            <div>
                <p class="stat-label">Total Students</p>
                <h3 class="stat-value">1,248</h3>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-box">
            <div class="stat-icon" style="background: rgba(59, 130, 246, 0.15);">
                <i class="bi bi-person-badge" style="color: #3b82f6;"></i>
            </div>
            <div>
                <p class="stat-label">Total Teachers</p>
                <h3 class="stat-value">84</h3>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-box">
            <div class="stat-icon" style="background: rgba(168, 85, 247, 0.15);">
                <i class="bi bi-door-open" style="color: #a855f7;"></i>
            </div>
            <div>
                <p class="stat-label">Total Classes</p>
                <h3 class="stat-value">32</h3>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-box">
            <div class="stat-icon" style="background: rgba(245, 158, 11, 0.15);">
                <i class="bi bi-currency-dollar" style="color: #f59e0b;"></i>
            </div>
            <div>
                <p class="stat-label">Total Fee Collection</p>
                <h3 class="stat-value">₹5.2L</h3>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-box">
            <div class="stat-icon" style="background: rgba(239, 68, 68, 0.15);">
                <i class="bi bi-exclamation-circle" style="color: #ef4444;"></i>
            </div>
            <div>
                <p class="stat-label">Pending Fees</p>
                <h3 class="stat-value">₹82K</h3>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card-surface">
            <h5 class="mb-3">Recent Activities</h5>
            <ul class="activity-list">
                <li>
                    <i class="bi bi-person-plus"></i>
                    <span>New student <strong>Rahul Kumar</strong> registered in Class 10-A</span>
                    <small class="text-muted">2 mins ago</small>
                </li>
                <li>
                    <i class="bi bi-cash"></i>
                    <span>Fee collected ₹15,000 from <strong>Priya Sharma</strong></span>
                    <small class="text-muted">15 mins ago</small>
                </li>
                <li>
                    <i class="bi bi-calendar-check"></i>
                    <span>Attendance marked for Class 8-B by <strong>Mr. Singh</strong></span>
                    <small class="text-muted">1 hour ago</small>
                </li>
                <li>
                    <i class="bi bi-journal-check"></i>
                    <span>Exam results published for <strong>Class 12 Mathematics</strong></span>
                    <small class="text-muted">3 hours ago</small>
                </li>
            </ul>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card-surface">
            <h5 class="mb-3">Quick Actions</h5>
            <div class="d-grid gap-2">
                @Html.ActionLink("Add New Student", "StudentRegistration", "Home", null, new { @class = "btn btn-outline-light text-start" })
                @Html.ActionLink("Mark Attendance", "Attendance", "Home", null, new { @class = "btn btn-outline-light text-start" })
                @Html.ActionLink("Collect Fees", "FeesCollection", "Home", null, new { @class = "btn btn-outline-light text-start" })
                @Html.ActionLink("Update Exam Results", "ExamManagement", "Home", null, new { @class = "btn btn-outline-light text-start" })
            </div>
        </div>
    </div>
</div>
