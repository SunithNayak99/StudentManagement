@{
    ViewBag.Title = "Login";
}

@section styles {
    <style>
        .login-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        
        .login-bg-elements {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: -1;
        }
        
        .login-bg-elements::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(108, 99, 255, 0.15), transparent 70%);
            border-radius: 50%;
            animation: float 8s ease-in-out infinite;
        }
        
        .login-bg-elements::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -10%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(0, 212, 255, 0.1), transparent 70%);
            border-radius: 50%;
            animation: float 6s ease-in-out infinite reverse;
        }
        
        .login-form-group {
            position: relative;
            margin-bottom: 1.5rem;
        }
        
        .login-form-group .form-control {
            padding-left: 45px;
        }
        
        .login-form-group .form-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            transition: color 0.3s ease;
            z-index: 2;
        }
        
        .login-form-group .form-control:focus + .form-icon {
            color: var(--accent);
        }
        
        .remember-forgot {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }
        
        .forgot-link {
            color: var(--muted);
            text-decoration: none;
            font-size: 0.9rem;
            transition: color 0.3s ease;
        }
        
        .forgot-link:hover {
            color: var(--accent);
        }
        
        .login-footer {
            text-align: center;
            margin-top: 2rem;
            padding-top: 2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .login-footer p {
            color: var(--muted);
            margin-bottom: 0;
        }
        
        .login-footer a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
        }
        
        .login-footer a:hover {
            text-decoration: underline;
        }
    </style>
}

<div class="login-container">
    <div class="login-bg-elements"></div>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7">
                <div class="auth-card">
                    <div class="text-center mb-4">
                        <span class="hero-badge">Welcome Back</span>
                        <h2>Login to StudentHub</h2>
                        <p>Access your dashboard, track students, and manage daily tasks.</p>
                    </div>
                    
                    <form id="loginForm">
                        <div class="login-form-group">
                            <label class="form-label">Username</label>
                            <input type="text" class="form-control" id="loginUsername" placeholder="Enter your username" required />
                            <i class="bi bi-person form-icon"></i>
                            <div class="invalid-feedback"></div>
                        </div>
                        
                        <div class="login-form-group">
                            <label class="form-label">Password</label>
                            <input type="password" class="form-control" id="loginPassword" placeholder="Enter your password" required />
                            <i class="bi bi-lock form-icon"></i>
                            <div class="invalid-feedback"></div>
                        </div>
                        
                        <div class="remember-forgot">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="rememberMe" />
                                <label class="form-check-label" for="rememberMe">Remember me</label>
                            </div>
                            <a href="#" class="forgot-link">Forgot password?</a>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="action-btn flex-grow-1" id="loginBtn">
                                <i class="bi bi-box-arrow-in-right"></i>
                                Login
                            </button>
                            <button type="reset" class="btn btn-outline-secondary" id="resetBtn" onclick="document.getElementById('loginUsername').classList.remove('is-invalid');document.getElementById('loginPassword').classList.remove('is-invalid');">
                                <i class="bi bi-arrow-counterclockwise"></i>
                                Reset
                            </button>
                        </div>
                    </form>
                    
                    <div class="login-footer">
                        <p>Don't have an account? @Html.ActionLink("Sign up here", "Signup", "Home", new { area = "" }, new { })</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/JavaScript/login.js"></script>
}
