@{
    ViewBag.Title = "Student Management Dashboard";
}

<section class="hero-section">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="hero-badge">Smart Student Operations</span>
            <h1 class="hero-title">Student <span>Management</span> Dashboard</h1>
            <p class="hero-text">Track student performance, automate enrollments, and keep communication flowing with a clean, modern workspace built for campus teams.</p>
            <div class="d-flex flex-wrap gap-3">
                <button class="action-btn" data-bs-toggle="modal" data-bs-target="#studentModal">
                    <i class="bi bi-plus-lg"></i>
                    Add Student
                </button>
                <button class="btn btn-outline-light">Generate Report</button>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="hero-card">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="mb-0">Today at a glance</h6>
                    <span class="pill">Live</span>
                </div>
                <div class="stats-grid">
                    <div class="stat-card">
                        <p class="stat-label">Total Students</p>
                        <h3 class="stat-value">1,248</h3>
                        <span class="stat-trend text-success"><i class="bi bi-arrow-up"></i> 4.2%</span>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">Active Courses</p>
                        <h3 class="stat-value">32</h3>
                        <span class="stat-trend text-info"><i class="bi bi-lightning"></i> 6 new</span>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">Avg. Attendance</p>
                        <h3 class="stat-value">94%</h3>
                        <span class="stat-trend text-success"><i class="bi bi-check-circle"></i> Stable</span>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">Mentor Sessions</p>
                        <h3 class="stat-value">18</h3>
                        <span class="stat-trend text-warning"><i class="bi bi-clock"></i> Upcoming</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="info-section">
    <div class="section-heading">
        <div>
            <h2 class="section-title">Campus Insights</h2>
            <p class="section-subtitle">Quick snapshots to keep your team aligned with student progress.</p>
        </div>
        <span class="pill">Updated 5 mins ago</span>
    </div>
    <div class="row g-4">
        <div class="col-md-6 col-lg-4">
            <div class="info-card">
                <div class="icon-circle"><i class="bi bi-people"></i></div>
                <h5>Engagement Pulse</h5>
                <p>Monitor active participation across courses, clubs, and mentoring sessions in real time.</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="info-card">
                <div class="icon-circle"><i class="bi bi-calendar2-week"></i></div>
                <h5>Schedule Overview</h5>
                <p>Keep tabs on this week’s top classes and workshops with easy schedule visibility.</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="info-card">
                <div class="icon-circle"><i class="bi bi-chat-dots"></i></div>
                <h5>Student Support</h5>
                <p>Track open support requests and resolve questions before the next check-in.</p>
            </div>
        </div>
    </div>
</section>

<header class="dashboard-header">
    <div>
        <p class="text-uppercase text-muted mb-1">Student Directory</p>
        <h2 class="h4 mb-0">Manage enrolled learners</h2>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-3">
        <div class="search-wrapper">
            <i class="bi bi-search"></i>
            <input type="text" class="search-input" placeholder="Search students..." />
        </div>
        <button class="action-btn" data-bs-toggle="modal" data-bs-target="#studentModal">
            <i class="bi bi-plus-lg"></i>
            Add Student
        </button>
    </div>
</header>

