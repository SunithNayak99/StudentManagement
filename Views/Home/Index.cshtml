                </li>
            </ul>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="info-panel">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h5 class="mb-0">Recent Activity</h5>
                <span class="pill">Live</span>
            </div>
