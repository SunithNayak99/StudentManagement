@{
    ViewBag.Title = "About";
}

<section class="row g-4 align-items-center">
    <div class="col-lg-6">
        <span class="hero-badge">About StudentHub</span>
        <h2 class="section-title">Designed for modern academic teams</h2>
        <p class="section-subtitle">StudentHub centralizes student information, attendance, and communication in one coordinated dashboard so teams can act quickly and stay aligned.</p>
        <div class="d-flex flex-wrap gap-3 mt-4">
            <div class="info-card flex-fill">
                <h5>Mission</h5>
                <p>Support student success with real-time visibility and proactive engagement tools.</p>
            </div>
            <div class="info-card flex-fill">
                <h5>Vision</h5>
                <p>Deliver a calm, collaborative workspace that helps mentors, advisors, and faculty stay connected.</p>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="info-panel">
            <h4 class="mb-3">Why teams love it</h4>
            <ul class="activity-list">
                <li><i class="bi bi-check-circle"></i>Instant access to enrollment, courses, and student status.</li>
                <li><i class="bi bi-check-circle"></i>Quick actions for scheduling, notes, and outreach.</li>
                <li><i class="bi bi-check-circle"></i>Professional design that keeps focus on the data.</li>
            </ul>
        </div>
    </div>
</section>
