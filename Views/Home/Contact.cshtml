@{
    ViewBag.Title = "Contact";
}

<section class="row g-4">
    <div class="col-lg-5">
        <div class="info-panel h-100">
            <h4 class="mb-3">Get in touch</h4>
            <p class="section-subtitle">Reach out to the StudentHub team for onboarding, support, or partnership opportunities.</p>
            <div class="mt-4">
                <p class="mb-2"><i class="bi bi-envelope"></i> support@studenthub.com</p>
                <p class="mb-2"><i class="bi bi-telephone"></i> +1 (415) 555-0184</p>
                <p class="mb-0"><i class="bi bi-geo-alt"></i> 300 Campus Ave, San Francisco, CA</p>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="auth-card">
            <h2>Send a message</h2>
            <p>Share your questions and we’ll respond within one business day.</p>
            <form>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">First Name</label>
                        <input type="text" class="form-control" placeholder="First name" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Last Name</label>
                        <input type="text" class="form-control" placeholder="Last name" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="name@school.edu" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Message</label>
                        <textarea class="form-control" rows="4" placeholder="Tell us how we can help"></textarea>
                    </div>
                </div>
                <button type="button" class="action-btn mt-4">Send Message</button>
            </form>
        </div>
    </div>
</section>
